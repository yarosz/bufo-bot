{
  "_metadata": {
    "major_version": 2,
    "minor_version": 1
  },
  "display_information": {
    "name": "Bufo",
    "description": "Daily bufo emoji rollout announcements and bufo discovery"
  },
  "features": {
    "bot_user": {
      "display_name": "Bufo",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/bufo-suggest",
        "description": "Get bufo emoji suggestions for any situation (powered by Claude)",
        "usage_hint": "[describe a situation or mood]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "chat:write.public",
        "reactions:read",
        "channels:read",
        "groups:read",
        "channels:manage",
        "groups:write",
        "reactions:write",
        "canvases:read",
        "canvases:write",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "reaction_added"
      ]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
