# Slack credentials for bufo emoji upload
#
# How to get these values:
#   1. Open Slack in your browser (not the desktop app)
#   2. Open DevTools (F12 or Cmd+Opt+I)
#
# COOKIE_D:
#   DevTools -> Application -> Cookies -> your-workspace.slack.com -> copy 'd' value
#
# TOKEN:
#   DevTools -> Console -> run: window.boot_data.api_token
#   Or: Network tab -> filter 'api/' -> copy 'token' from any request payload
#
# WORKSPACE:
#   Your Slack workspace subdomain (the part before .slack.com)

COOKIE_D=xoxd-...
WORKSPACE=mycompany
TOKEN=xoxc-...

# Bot tokens (from Slack app settings)
BOT_TOKEN=xoxb-...
APP_TOKEN=xapp-...

# Channel IDs (find via right-click channel -> View channel details -> copy ID)
BUFO_CHANNEL_ID=
BUFO_META_CHANNEL_ID=
BUFO_TEST_CHANNEL_ID=

# Opt-out canvas ID (Slack canvas for tracking users who opted out of discovery)
OPT_OUT_CANVAS_ID=

# Optional: 1Password refs for Slack config token management
# OP_SLACK_ACCESS_TOKEN=op://Vault/item/field
# OP_SLACK_REFRESH_TOKEN=op://Vault/item/field
