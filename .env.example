# Slack credentials for bufo emoji upload
#
# How to get these values:
#   1. Open Slack in your browser (not the desktop app)
#   2. Open DevTools (F12 or Cmd+Opt+I)
#
# COOKIE_D:
#   DevTools -> Application -> Cookies -> your-workspace.slack.com -> copy 'd' value
#
# TOKEN:
#   DevTools -> Console -> run: window.boot_data.api_token
#   Or: Network tab -> filter 'api/' -> copy 'token' from any request payload
#
# WORKSPACE:
#   Your Slack workspace subdomain (the part before .slack.com)

COOKIE_D=xoxd-...
WORKSPACE=mycompany
TOKEN=xoxc-...
